<%-
  @acl = []
  # use function in group slave to get titles
  if @provide_xfrs.any?
    @notify_out = (@provide_xfrs + @send_notify_additions + @exported_remotes).map {
      |notify| "#{notify}-notify"
    }
    @acl        += (@provide_xfrs + @exported_remotes).map{
      |xfr| "#{xfr}-transfer"
    }
  else
    @notify_out = (@default_provide_xfrs + @send_notify_additions + @exported_remotes).map {
      |notify| "#{notify}-notify"
    }
    @acl        += (@default_provide_xfrs + @exported_remotes).map{
      |xfr| "#{xfr}-transfer"
    }
  end
  if @masters.any?
    @acl  += (@masters + @allow_notify_additions).map{
      |notify| "#{notify}-notify"
    }
  else
    @acl  += (@default_masters + @allow_notify_additions).map{
      |notify| "#{notify}-notify"
    }
  end
-%>
  - domain: <%= @name %>
<%- if @zonefile -%>
    file: <%= @zone_subdir %>/<%= @zonefile %>
<%- else -%>
    file: <%= @zone_subdir %>/<%= @name %>
<%- end -%>
<%- if @notify_out.any? -%>
    notify: [<%= @notify_out.join(', ') %>]
<%- end -%>
<%- if @acl.any? -%>
    acl: [<%= @acl.join(', ') %>]
<%- end -%>
<%- if @masters.any? -%>
    master: [<%= @masters.join(', ') %>]
<%- elsif @default_masters.any? -%>
    master: [<%= @default_masters.join(', ') %>]
<%- end -%>
<%- if @zonemd_verify -%>
    zonemd-verify: <%= @zonemd_verify %>
<%- end -%>
<%- if @zonemd_generate -%>
    zonemd-generate: <%= @zonemd_generate %>
<%- end -%>
<%- if @_refresh_min_interval.kind_of?(Integer) -%>
    refresh-min-interval: <%= @_refresh_min_interval %>
<%- end -%>
<%- if @_refresh_max_interval.kind_of?(Integer) -%>
    refresh-max-interval: <%= @_refresh_max_interval %>
<%- end -%>
<%- if @_retry_min_interval.kind_of?(Integer) -%>
    retry-min-interval: <%= @_retry_min_interval %>
<%- end -%>
<%- if @_retry_max_interval.kind_of?(Integer) -%>
    retry-max-interval: <%= @_retry_max_interval %>
<%- end -%>
<%- if @_expire_min_interval.kind_of?(Integer) -%>
    expire-min-interval: <%= @_expire_min_interval %>
<%- end -%>
<%- if @_expire_max_interval.kind_of?(Integer) -%>
    expire-max-interval: <%= @_expire_max_interval %>
<%- end -%>