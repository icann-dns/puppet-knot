<%-
if @tcp_workers.nil?
  @tcp_workers = (@server_count * 0.2).floor
  @tcp_workers = @tcp_workers > 0 ? @tcp_workers : 1
end
if @udp_workers.nil?
  @udp_workers = @server_count - @tcp_workers - @background_workers
  @udp_workers = @udp_workers > 0 ? @udp_workers : 1
end
-%>
server:
  identity: <%= @identity %>
<%- if @hide_version -%>
  version: hidden
<%- elsif @version -%>
  version: <%= @version %>
<%- end -%>
  nsid: <%= @nsid %>
  rundir: <%= @run_dir %>
  pidfile: <%= @pidfile %>
  udp-workers: <%= @udp_workers %>
  tcp-workers: <%= @tcp_workers %>
  background-workers: <%= @background_workers %>
  server.tcp-max-clients: <%= @max_tcp_clients %>
  server.udp-max-payload: <%= @max_udp_payload %>
  user: <%= @username %>
<%- if @port == 53 then port_str = '' else port_str = "@#{@port}" end -%>
  listen: [<%= @ip_addresses.join("#{port_str}, ") %><%= port_str %>]
<%- if @rrl_enable -%>
mod-rrl:
  - id: default
    rate-limit: <%= @rrl_limit %>
    table-size: <%= @rrl_size %>
    slip: <%= @rrl_slip %>
template:
  - id: default
    global-module: mod-rrl/default 
<%- end -%>
<%- if @control_enable -%>
control:
  listen: <%= @run_dir %>/knot.sock
<%- end -%>
log:
  - target: <%= @log_target %>
    any: <%= @log_any_level %>
    zone: <%= @log_zone_level %>
    server: <%= @log_server_level %>
